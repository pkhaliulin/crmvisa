# 12. \uc0\u1051 \u1086 \u1075 \u1080 \u1082 \u1072  \u1080 \u1090 \u1086 \u1075 \u1086 \u1074 \u1086 \u1075 \u1086  risk score \u1087 \u1086  \u1079 \u1072 \u1103 \u1074 \u1082 \u1077                                                                                                                                         \
                                                                                                                                                                                   \
\uc0\u1057 \u1080 \u1089 \u1090 \u1077 \u1084 \u1072  \u1076 \u1086 \u1083 \u1078 \u1085 \u1072  \u1089 \u1095 \u1080 \u1090 \u1072 \u1090 \u1100  \u1085 \u1077  \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  document-level, \u1085 \u1086  \u1080  case-level risk:                                                                                                             \
                                                                                                                                                                                   \
## Formula idea                                                                                                                                                                    \
                                                                                                                                                                                   \
`case_risk = weighted(sum(document risks + mismatch risks + country critical rules not satisfied - positive factors))`                                                             \
                                                                                                                                                                                   \
### \uc0\u1060 \u1072 \u1082 \u1090 \u1086 \u1088 \u1099 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1077  \u1087 \u1086 \u1074 \u1099 \u1096 \u1072 \u1102 \u1090  \u1088 \u1080 \u1089 \u1082 :                                                                                                                                                \
                                                                                                                                                                                   \
* missing required doc                                                                                                                                                             \
* low OCR quality                                                                                                                                                                  \
* mismatch with passport                                                                                                                                                           \
* mismatch with dates                                                                                                                                                              \
* unexplained funds                                                                                                                                                                \
* weak purpose evidence                                                                                                                                                            \
* weak ties to home country                                                                                                                                                        \
* suspicious sponsor                                                                                                                                                               \
                                                                                                                                                                                   \
### \uc0\u1060 \u1072 \u1082 \u1090 \u1086 \u1088 \u1099 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1077  \u1089 \u1085 \u1080 \u1078 \u1072 \u1102 \u1090  \u1088 \u1080 \u1089 \u1082 :                                                                                                                                                 \
                                                                                                                                                                                   \
* strong travel history                                                                                                                                                            \
* stable employment                                                                                                                                                                \
* strong financials                                                                                                                                                                \
* strong academic logic                                                                                                                                                            \
* clear business objective                                                                                                                                                         \
* complete and consistent file                                                                                                                                                     \
                                                                                                                                                                                   \
